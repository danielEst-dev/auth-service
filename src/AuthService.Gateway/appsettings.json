{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "auth-service",
    "PublicKeyPem": ""
  },
  "ReverseProxy": {
    "Routes": {
      "auth-grpc-route": {
        "ClusterId": "auth-grpc-cluster",
        "Match": {
          "Path": "/auth.AuthService/{**catch-all}"
        }
      },
      "tenant-grpc-route": {
        "ClusterId": "auth-grpc-cluster",
        "Match": {
          "Path": "/tenant.TenantService/{**catch-all}"
        }
      },
      "roles-grpc-route": {
        "ClusterId": "auth-grpc-cluster",
        "Match": {
          "Path": "/roles.RoleService/{**catch-all}"
        }
      },
      "mfa-grpc-route": {
        "ClusterId": "auth-grpc-cluster",
        "Match": {
          "Path": "/mfa.MfaService/{**catch-all}"
        }
      },
      "verification-grpc-route": {
        "ClusterId": "auth-grpc-cluster",
        "Match": {
          "Path": "/verification.VerificationService/{**catch-all}"
        }
      },
      "oidc-authorize-route": {
        "ClusterId": "auth-grpc-cluster",
        "Match": {
          "Path": "/oauth/authorize"
        }
      },
      "oidc-token-route": {
        "ClusterId": "auth-grpc-cluster",
        "Match": {
          "Path": "/oauth/token"
        }
      },
      "oidc-userinfo-route": {
        "ClusterId": "auth-grpc-cluster",
        "Match": {
          "Path": "/oauth/userinfo"
        }
      },
      "oidc-discovery-route": {
        "ClusterId": "auth-grpc-cluster",
        "Match": {
          "Path": "/.well-known/openid-configuration"
        }
      },
      "oidc-jwks-route": {
        "ClusterId": "auth-grpc-cluster",
        "Match": {
          "Path": "/oauth/jwks"
        }
      }
    },
    "Clusters": {
      "auth-grpc-cluster": {
        "Destinations": {
          "auth-grpc-primary": {
            "Address": "http://localhost:5100"
          }
        }
      }
    }
  }
}