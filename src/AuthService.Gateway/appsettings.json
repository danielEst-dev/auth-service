{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "auth-service"
  },
  "ReverseProxy": {
    "Routes": {
      "auth-grpc-route": {
        "ClusterId": "auth-grpc-cluster",
        "Match": {
          "Path": "/auth.AuthService/{**catch-all}"
        }
      },
      "tenant-grpc-route": {
        "ClusterId": "auth-grpc-cluster",
        "Match": {
          "Path": "/tenant.TenantService/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-grpc-cluster": {
        "Destinations": {
          "auth-grpc-primary": {
            "Address": "http://localhost:5000"
          }
        }
      }
    }
  }
}