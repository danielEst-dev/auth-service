{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Grpc": "Information"
      }
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Grpc": {
        "Url": "http://localhost:5100",
        "Protocols": "Http2"
      },
      "Http": {
        "Url": "http://localhost:5101",
        "Protocols": "Http1"
      }
    }
  },
  "ConnectionStrings": {
    "Postgres": "",
    "Redis": ""
  },
  "RabbitMQ": {
    "Host": "localhost",
    "VirtualHost": "auth_vhost",
    "Username": "auth_user",
    "Password": ""
  },
  "OpenTelemetry": {
    "Endpoint": "http://localhost:4317"
  },
  "Jwt": {
    "Issuer": "auth-service",
    "AccessTokenLifetimeMinutes": 15,
    "RefreshTokenLifetimeDays": 7,
    "PrivateKeyPem": "",
    "PublicKeyPem": ""
  }
}
